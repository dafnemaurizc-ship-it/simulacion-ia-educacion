<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_ASIS_TOBE_Educacion_IA_Revisado" targetNamespace="http://chatgpt.openai.com/bpmn/simulacion-educacion-ia-revisado" exporter="ChatGPT" exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_ASIS_TOBE_Revisado">
    <bpmn:participant id="Participant_ASIS" name="AS IS - Educación tradicional" processRef="Process_ASIS"/>
    <bpmn:participant id="Participant_TOBE" name="TO BE - Educación personalizada con IA" processRef="Process_TOBE"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_ASIS" name="AS IS - Flujo tradicional de enseñanza y seguimiento académico" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_ASIS">
      <bpmn:lane id="Lane_ASIS_Estudiante" name="Estudiante">
        <bpmn:flowNodeRef>Start_ASIS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_Asistir</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ASIS_Docente" name="Docente">
        <bpmn:flowNodeRef>Task_ASIS_Planificar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_Dictar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_Evaluar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_RegistrarNota</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ASIS_Nota</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_BajoRendimiento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ASIS_RiesgoTiempo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_RetroManual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_Recuperacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ASIS_Recupera</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ASIS_Abandona</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_ASIS_Coordinacion" name="Coordinación académica">
        <bpmn:flowNodeRef>Task_ASIS_Aprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_Desaprobado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_Desercion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ASIS_Consolidar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ASIS</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_ASIS" name="Inicio del ciclo académico">
      <bpmn:outgoing>Flow_ASIS_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_ASIS_Planificar" name="Planificar clase tradicional">
      <bpmn:incoming>Flow_ASIS_01</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ASIS_Dictar" name="Impartir clase general">
      <bpmn:incoming>Flow_ASIS_02</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ASIS_Asistir" name="Asistir y estudiar con recursos estándar">
      <bpmn:incoming>Flow_ASIS_03</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ASIS_Evaluar" name="Aplicar evaluación estandarizada">
      <bpmn:incoming>Flow_ASIS_04</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ASIS_RegistrarNota" name="Registrar calificación">
      <bpmn:incoming>Flow_ASIS_05</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ASIS_Nota" name="¿Nota &gt;= 11?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_ASIS_06</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_07</bpmn:outgoing>
      <bpmn:outgoing>Flow_ASIS_08</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ASIS_Aprobado" name="Registrar aprobado">
      <bpmn:incoming>Flow_ASIS_07</bpmn:incoming>
      <bpmn:incoming>Flow_ASIS_13</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ASIS_BajoRendimiento" name="Identificar bajo rendimiento">
      <bpmn:incoming>Flow_ASIS_08</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_09</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ASIS_RiesgoTiempo" name="¿Riesgo detectado a tiempo?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_ASIS_09</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_10</bpmn:outgoing>
      <bpmn:outgoing>Flow_ASIS_15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ASIS_RetroManual" name="Brindar retroalimentación manual">
      <bpmn:incoming>Flow_ASIS_10</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ASIS_Recuperacion" name="Aplicar recuperación general">
      <bpmn:incoming>Flow_ASIS_11</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ASIS_Recupera" name="¿Recupera nota?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_ASIS_12</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_13</bpmn:outgoing>
      <bpmn:outgoing>Flow_ASIS_14</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_ASIS_Abandona" name="¿Abandona el curso?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_ASIS_14</bpmn:incoming>
      <bpmn:incoming>Flow_ASIS_15</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_16</bpmn:outgoing>
      <bpmn:outgoing>Flow_ASIS_17</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ASIS_Desaprobado" name="Registrar desaprobado">
      <bpmn:incoming>Flow_ASIS_17</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_19</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ASIS_Desercion" name="Registrar deserción">
      <bpmn:incoming>Flow_ASIS_16</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_20</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ASIS_Consolidar" name="Consolidar rendimiento, aprobación y deserción">
      <bpmn:incoming>Flow_ASIS_18</bpmn:incoming>
      <bpmn:incoming>Flow_ASIS_19</bpmn:incoming>
      <bpmn:incoming>Flow_ASIS_20</bpmn:incoming>
      <bpmn:outgoing>Flow_ASIS_21</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_ASIS" name="Reporte tradicional generado">
      <bpmn:incoming>Flow_ASIS_21</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ASIS_01" sourceRef="Start_ASIS" targetRef="Task_ASIS_Planificar"/>
    <bpmn:sequenceFlow id="Flow_ASIS_02" sourceRef="Task_ASIS_Planificar" targetRef="Task_ASIS_Dictar"/>
    <bpmn:sequenceFlow id="Flow_ASIS_03" sourceRef="Task_ASIS_Dictar" targetRef="Task_ASIS_Asistir"/>
    <bpmn:sequenceFlow id="Flow_ASIS_04" sourceRef="Task_ASIS_Asistir" targetRef="Task_ASIS_Evaluar"/>
    <bpmn:sequenceFlow id="Flow_ASIS_05" sourceRef="Task_ASIS_Evaluar" targetRef="Task_ASIS_RegistrarNota"/>
    <bpmn:sequenceFlow id="Flow_ASIS_06" sourceRef="Task_ASIS_RegistrarNota" targetRef="Gateway_ASIS_Nota"/>
    <bpmn:sequenceFlow id="Flow_ASIS_07" sourceRef="Gateway_ASIS_Nota" targetRef="Task_ASIS_Aprobado" name="Sí"/>
    <bpmn:sequenceFlow id="Flow_ASIS_08" sourceRef="Gateway_ASIS_Nota" targetRef="Task_ASIS_BajoRendimiento" name="No"/>
    <bpmn:sequenceFlow id="Flow_ASIS_09" sourceRef="Task_ASIS_BajoRendimiento" targetRef="Gateway_ASIS_RiesgoTiempo"/>
    <bpmn:sequenceFlow id="Flow_ASIS_10" sourceRef="Gateway_ASIS_RiesgoTiempo" targetRef="Task_ASIS_RetroManual" name="Sí"/>
    <bpmn:sequenceFlow id="Flow_ASIS_11" sourceRef="Task_ASIS_RetroManual" targetRef="Task_ASIS_Recuperacion"/>
    <bpmn:sequenceFlow id="Flow_ASIS_12" sourceRef="Task_ASIS_Recuperacion" targetRef="Gateway_ASIS_Recupera"/>
    <bpmn:sequenceFlow id="Flow_ASIS_13" sourceRef="Gateway_ASIS_Recupera" targetRef="Task_ASIS_Aprobado" name="Sí"/>
    <bpmn:sequenceFlow id="Flow_ASIS_14" sourceRef="Gateway_ASIS_Recupera" targetRef="Gateway_ASIS_Abandona" name="No"/>
    <bpmn:sequenceFlow id="Flow_ASIS_15" sourceRef="Gateway_ASIS_RiesgoTiempo" targetRef="Gateway_ASIS_Abandona" name="No"/>
    <bpmn:sequenceFlow id="Flow_ASIS_16" sourceRef="Gateway_ASIS_Abandona" targetRef="Task_ASIS_Desercion" name="Sí"/>
    <bpmn:sequenceFlow id="Flow_ASIS_17" sourceRef="Gateway_ASIS_Abandona" targetRef="Task_ASIS_Desaprobado" name="No"/>
    <bpmn:sequenceFlow id="Flow_ASIS_18" sourceRef="Task_ASIS_Aprobado" targetRef="Task_ASIS_Consolidar"/>
    <bpmn:sequenceFlow id="Flow_ASIS_19" sourceRef="Task_ASIS_Desaprobado" targetRef="Task_ASIS_Consolidar"/>
    <bpmn:sequenceFlow id="Flow_ASIS_20" sourceRef="Task_ASIS_Desercion" targetRef="Task_ASIS_Consolidar"/>
    <bpmn:sequenceFlow id="Flow_ASIS_21" sourceRef="Task_ASIS_Consolidar" targetRef="End_ASIS"/>
  </bpmn:process>
  <bpmn:process id="Process_TOBE" name="TO BE - Flujo con sistema de educación personalizada con IA" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Process_TOBE">
      <bpmn:lane id="Lane_TOBE_Estudiante" name="Estudiante">
        <bpmn:flowNodeRef>Start_TOBE</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_Diagnostico</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_ResolverActividades</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_RecibirRecursos</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TOBE_Docente" name="Docente">
        <bpmn:flowNodeRef>Task_TOBE_DefinirCurso</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_DesarrollarSesion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_RevisarSugerencia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TOBE_ValidaAjuste</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_AjustarIntervencion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_AplicarIntervencion</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TOBE_IA" name="Sistema de educación personalizada con IA">
        <bpmn:flowNodeRef>Task_TOBE_CapturarVariables</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_PerfilAprendizaje</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_Monitorear</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TOBE_Progreso</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_ActividadAvance</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_DetectarDificultad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_Alerta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_Refuerzo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TOBE_UnirIntervencion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_ActualizarPerfil</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TOBE_FinPeriodo</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TOBE_Simulacion" name="Motor de simulación y analítica">
        <bpmn:flowNodeRef>Task_TOBE_SimTradicional</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_SimIA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_CompararIndicadores</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TOBE_Coordinacion" name="Coordinación académica">
        <bpmn:flowNodeRef>Task_TOBE_ReporteImpacto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_TOBE_Mejora</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_Implementar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TOBE_RevisarParametros</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_TOBE</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_TOBE" name="Inicio del ciclo con IA personalizada">
      <bpmn:outgoing>Flow_TOBE_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_TOBE_DefinirCurso" name="Definir objetivos, contenidos y criterios">
      <bpmn:incoming>Flow_TOBE_01</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_02</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_TOBE_Diagnostico" name="Realizar diagnóstico académico inicial">
      <bpmn:incoming>Flow_TOBE_02</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_03</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_TOBE_CapturarVariables" name="Capturar variables académicas iniciales">
      <bpmn:incoming>Flow_TOBE_03</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_04</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_TOBE_PerfilAprendizaje" name="Construir perfil de aprendizaje">
      <bpmn:incoming>Flow_TOBE_04</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_05</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_TOBE_DesarrollarSesion" name="Desarrollar sesión de aprendizaje">
      <bpmn:incoming>Flow_TOBE_05</bpmn:incoming>
      <bpmn:incoming>Flow_TOBE_23</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_06</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_TOBE_ResolverActividades" name="Resolver actividades y evaluaciones formativas">
      <bpmn:incoming>Flow_TOBE_06</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_07</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_TOBE_Monitorear" name="Monitorear progreso y participación">
      <bpmn:incoming>Flow_TOBE_07</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_08</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_TOBE_Progreso" name="¿Progreso adecuado?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_TOBE_08</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_09</bpmn:outgoing>
      <bpmn:outgoing>Flow_TOBE_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_TOBE_ActividadAvance" name="Proponer actividad de avance">
      <bpmn:incoming>Flow_TOBE_09</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_13</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_TOBE_DetectarDificultad" name="Detectar dificultad y riesgo académico">
      <bpmn:incoming>Flow_TOBE_10</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_TOBE_Alerta" name="Generar alerta temprana">
      <bpmn:incoming>Flow_TOBE_11</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_TOBE_Refuerzo" name="Proponer refuerzo personalizado">
      <bpmn:incoming>Flow_TOBE_12</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_14</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_TOBE_UnirIntervencion" name="Unir rutas" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_TOBE_13</bpmn:incoming>
      <bpmn:incoming>Flow_TOBE_14</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_15</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_TOBE_RevisarSugerencia" name="Revisar sugerencia pedagógica de IA">
      <bpmn:incoming>Flow_TOBE_15</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_16</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_TOBE_ValidaAjuste" name="¿Ajuste validado?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_TOBE_16</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_17</bpmn:outgoing>
      <bpmn:outgoing>Flow_TOBE_18</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_TOBE_AjustarIntervencion" name="Ajustar intervención docente">
      <bpmn:incoming>Flow_TOBE_18</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_19</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_TOBE_AplicarIntervencion" name="Aplicar intervención personalizada">
      <bpmn:incoming>Flow_TOBE_17</bpmn:incoming>
      <bpmn:incoming>Flow_TOBE_19</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_20</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_TOBE_RecibirRecursos" name="Recibir recursos y retroalimentación adaptada">
      <bpmn:incoming>Flow_TOBE_20</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_21</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_TOBE_ActualizarPerfil" name="Actualizar perfil y registrar avance">
      <bpmn:incoming>Flow_TOBE_21</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_22</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_TOBE_FinPeriodo" name="¿Finalizó el periodo?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_TOBE_22</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_23</bpmn:outgoing>
      <bpmn:outgoing>Flow_TOBE_24</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_TOBE_SimTradicional" name="Simular flujo tradicional AS IS">
      <bpmn:incoming>Flow_TOBE_24</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_25</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_TOBE_SimIA" name="Simular flujo con IA personalizada">
      <bpmn:incoming>Flow_TOBE_25</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_26</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_TOBE_CompararIndicadores" name="Comparar indicadores: rendimiento, aprobación y deserción">
      <bpmn:incoming>Flow_TOBE_26</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_27</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_TOBE_ReporteImpacto" name="Generar reporte de impacto académico">
      <bpmn:incoming>Flow_TOBE_27</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_28</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_TOBE_Mejora" name="¿IA mejora indicadores?" gatewayDirection="Diverging">
      <bpmn:incoming>Flow_TOBE_28</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_29</bpmn:outgoing>
      <bpmn:outgoing>Flow_TOBE_30</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_TOBE_Implementar" name="Planificar implementación institucional">
      <bpmn:incoming>Flow_TOBE_29</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_31</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_TOBE_RevisarParametros" name="Revisar parámetros y estrategia pedagógica">
      <bpmn:incoming>Flow_TOBE_30</bpmn:incoming>
      <bpmn:outgoing>Flow_TOBE_32</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_TOBE" name="Decisión académica basada en simulación">
      <bpmn:incoming>Flow_TOBE_31</bpmn:incoming>
      <bpmn:incoming>Flow_TOBE_32</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_TOBE_01" sourceRef="Start_TOBE" targetRef="Task_TOBE_DefinirCurso"/>
    <bpmn:sequenceFlow id="Flow_TOBE_02" sourceRef="Task_TOBE_DefinirCurso" targetRef="Task_TOBE_Diagnostico"/>
